# Copy to kaliyai-rag/.env (gitignored). Same key family as the Android app / Codespaces.
# You can also set GEMINI_API_KEY in ../castalia.institute/.env and symlink or duplicate here for CLI use.
GEMINI_API_KEY=

# Optional: match embedding dimensions if you change Gemini outputDimensionality (must match SQL vector(N)).
# KALIYAI_EMBEDDING_DIMENSION=768

# Optional: Supabase (server-side ingestion only — never embed service role in the APK)
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=
