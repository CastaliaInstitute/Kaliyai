# OS / editor
.DS_Store
.idea/
*.iml
.vscode/

# Gradle / Android
.gradle/
.kotlin/
build/
*/build/
local.properties

# Secrets
.env
*.keystore
*.jks

# Python
__pycache__/
*.pyc
.venv/
venv/

# Large prep artifacts (ROMs, rootfs, installers) — keep scripts/docs only
nethunter-prep/*.zip
nethunter-prep/*.img
nethunter-prep/*.apk
nethunter-prep/*.tar
nethunter-prep/*.tar.xz
nethunter-prep/*.tar.gz
nethunter-prep/SHA256SUMS
nethunter-prep/neth-extract/
# OpenVAS: track scripts; never commit admin creds
nethunter-prep/openvas/**/.secrets/
nethunter-prep/openvas/**/.secrets/**

# Logs / temp
*.log
tmp/

# Kaliyai RAG local corpus + secrets (see kaliyai-rag/README.md)
kaliyai-rag/data/
kaliyai-rag/.env
kaliyai-rag/**/*.db
# Bulk cloned repos + downloaded PDFs/feeds (see kaliyai-rag/docs/CORPUS_SEED_PACK.md)
kaliyai-rag/sources/
